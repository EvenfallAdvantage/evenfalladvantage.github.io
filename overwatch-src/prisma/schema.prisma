generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// PLATFORM & MULTI-TENANCY
// ─────────────────────────────────────────────

model User {
  id            String   @id @default(uuid()) @db.Uuid
  email         String?  @unique
  phone         String?  @unique
  firstName     String   @map("first_name")
  lastName      String   @map("last_name")
  avatarUrl     String?  @map("avatar_url")
  supabaseId    String?  @unique @map("supabase_id")
  isPlatformAdmin Boolean @default(false) @map("is_platform_admin")
  lastLoginAt   DateTime? @map("last_login_at")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  memberships         CompanyMembership[]
  timesheets          Timesheet[]
  timesheetsApproved  Timesheet[]         @relation("TimesheetApprover")
  certifications      Certification[]
  assetHolder         Asset[]             @relation("AssetHolder")
  assetLogs           AssetLog[]
  shiftAssignments    Shift[]
  eventInterests      EventInterest[]
  timeOffRequests     TimeOffRequest[]
  timeOffApprovals    TimeOffRequest[]    @relation("TimeOffApprover")
  formSubmissions     FormSubmission[]
  formReviews         FormSubmission[]    @relation("FormReviewer")
  quizAttempts        QuizAttempt[]
  courseEnrollments    CourseEnrollment[]
  chatMessages        ChatMessage[]
  chatMemberships     ChatMember[]
  posts               Post[]
  postComments        PostComment[]
  postReactions       PostReaction[]
  notifications       Notification[]
  auditLogs           AuditLog[]
  documentsCreated    KBDocument[]

  @@map("users")
}

model Company {
  id          String   @id @default(uuid()) @db.Uuid
  name        String
  slug        String   @unique
  logoUrl     String?  @map("logo_url")
  joinCode    String   @unique @map("join_code")
  timezone    String   @default("America/Los_Angeles")
  brandColor  String   @default("#6366f1") @map("brand_color")
  settings    Json     @default("{}")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  memberships       CompanyMembership[]
  events            Event[]
  assets            Asset[]
  assetLogs         AssetLog[]
  clients           Client[]
  forms             Form[]
  quizzes           Quiz[]
  courses           Course[]
  kbFolders         KBFolder[]
  chatChannels      ChatChannel[]
  posts             Post[]
  notifications     Notification[]
  auditLogs         AuditLog[]
  timeOffPolicies   TimeOffPolicy[]

  @@map("companies")
}

enum CompanyRole {
  owner
  admin
  manager
  lead
  breaker
  staff
}

model CompanyMembership {
  id        String      @id @default(uuid()) @db.Uuid
  userId    String      @map("user_id") @db.Uuid
  companyId String      @map("company_id") @db.Uuid
  role      CompanyRole @default(staff)
  title     String?
  nickname  String?
  pronouns  String?
  bio       String?
  dietaryPreferences String? @map("dietary_preferences")
  shirtSize  String?    @map("shirt_size")
  jacketSize String?    @map("jacket_size")
  guardCardNumber  String? @map("guard_card_number")
  guardCardExpiry  DateTime? @map("guard_card_expiry")
  emergencyContactName  String? @map("emergency_contact_name")
  emergencyContactPhone String? @map("emergency_contact_phone")
  address   String?
  hireDate  DateTime?  @map("hire_date")
  status    String     @default("active")
  workPreferences String[] @map("work_preferences")
  whatsappOptedIn Boolean @default(false) @map("whatsapp_opted_in")
  onboardingComplete Boolean @default(false) @map("onboarding_complete")
  kioskPin  String?    @map("kiosk_pin")
  qrCodeId  String?    @map("qr_code_id")
  notificationDays String[] @default(["Mon","Tue","Wed","Thu","Fri","Sat","Sun"]) @map("notification_days")
  notificationsMuted Boolean @default(false) @map("notifications_muted")
  createdAt DateTime   @default(now()) @map("created_at")
  updatedAt DateTime   @updatedAt @map("updated_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([userId, companyId])
  @@index([companyId])
  @@map("company_memberships")
}

// ─────────────────────────────────────────────
// CLIENTS & EVENTS
// ─────────────────────────────────────────────

model Client {
  id           String   @id @default(uuid()) @db.Uuid
  companyId    String   @map("company_id") @db.Uuid
  name         String
  contactName  String?  @map("contact_name")
  contactEmail String?  @map("contact_email")
  contactPhone String?  @map("contact_phone")
  address      String?
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  events  Event[]

  @@index([companyId])
  @@map("clients")
}

model Event {
  id              String   @id @default(uuid()) @db.Uuid
  companyId       String   @map("company_id") @db.Uuid
  clientId        String?  @map("client_id") @db.Uuid
  name            String
  description     String?
  location        String?
  locationLat     Float?   @map("location_lat")
  locationLng     Float?   @map("location_lng")
  geofenceRadius  Int?     @map("geofence_radius_meters")
  startDate       DateTime @map("start_date")
  endDate         DateTime @map("end_date")
  status          String   @default("draft")
  whatsappGroupId String?  @map("whatsapp_group_id")
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  company   Company         @relation(fields: [companyId], references: [id], onDelete: Cascade)
  client    Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  shifts    Shift[]
  interests EventInterest[]
  assetLogs AssetLog[]

  @@index([companyId, status])
  @@index([startDate])
  @@map("events")
}

model EventInterest {
  id         String    @id @default(uuid()) @db.Uuid
  eventId    String    @map("event_id") @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  status     String    @default("interested")
  respondedAt DateTime @default(now()) @map("responded_at")
  acceptedAt DateTime? @map("accepted_at")

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@map("event_interests")
}

// ─────────────────────────────────────────────
// SCHEDULING & TIME
// ─────────────────────────────────────────────

model Shift {
  id             String   @id @default(uuid()) @db.Uuid
  eventId        String   @map("event_id") @db.Uuid
  assignedUserId String?  @map("assigned_user_id") @db.Uuid
  role           String?
  startTime      DateTime @map("start_time")
  endTime        DateTime @map("end_time")
  status         String   @default("open")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  event        Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  assignedUser User?       @relation(fields: [assignedUserId], references: [id], onDelete: SetNull)
  timesheets   Timesheet[]

  @@index([eventId])
  @@index([assignedUserId])
  @@index([startTime])
  @@map("shifts")
}

model Timesheet {
  id           String    @id @default(uuid()) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  shiftId      String?   @map("shift_id") @db.Uuid
  clockIn      DateTime  @map("clock_in")
  clockOut     DateTime? @map("clock_out")
  clockMethod  String    @default("app") @map("clock_method")
  breakMinutes Int       @default(0) @map("break_minutes")
  approved     Boolean   @default(false)
  approvedById String?   @map("approved_by_id") @db.Uuid
  approvedAt   DateTime? @map("approved_at")
  qbSynced     Boolean   @default(false) @map("qb_synced")
  notes        String?
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  shift      Shift? @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  approvedBy User?  @relation("TimesheetApprover", fields: [approvedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([clockIn])
  @@map("timesheets")
}

// ─────────────────────────────────────────────
// TIME OFF
// ─────────────────────────────────────────────

model TimeOffPolicy {
  id            String  @id @default(uuid()) @db.Uuid
  companyId     String  @map("company_id") @db.Uuid
  name          String
  type          String
  accrualRate   Float?  @map("accrual_rate")
  accrualPeriod String? @map("accrual_period")
  maxBalance    Float?  @map("max_balance")
  createdAt     DateTime @default(now()) @map("created_at")

  company  Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  requests TimeOffRequest[]

  @@index([companyId])
  @@map("time_off_policies")
}

model TimeOffRequest {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  policyId   String    @map("policy_id") @db.Uuid
  startDate  DateTime  @map("start_date")
  endDate    DateTime  @map("end_date")
  note       String?
  status     String    @default("pending")
  reviewedById String? @map("reviewed_by_id") @db.Uuid
  reviewedAt DateTime? @map("reviewed_at")
  createdAt  DateTime  @default(now()) @map("created_at")

  user       User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  policy     TimeOffPolicy @relation(fields: [policyId], references: [id], onDelete: Cascade)
  reviewedBy User?         @relation("TimeOffApprover", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("time_off_requests")
}

// ─────────────────────────────────────────────
// ASSETS & INVENTORY
// ─────────────────────────────────────────────

model Asset {
  id              String   @id @default(uuid()) @db.Uuid
  companyId       String   @map("company_id") @db.Uuid
  name            String
  assetType       String?  @map("asset_type")
  serialNumber    String?  @map("serial_number")
  qrCode          String   @unique @map("qr_code")
  status          String   @default("available")
  condition       String   @default("good")
  currentHolderId String?  @map("current_holder_id") @db.Uuid
  notes           String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  company       Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  currentHolder User?      @relation("AssetHolder", fields: [currentHolderId], references: [id], onDelete: SetNull)
  logs          AssetLog[]

  @@index([companyId, status])
  @@map("assets")
}

model AssetLog {
  id                String   @id @default(uuid()) @db.Uuid
  assetId           String   @map("asset_id") @db.Uuid
  userId            String   @map("user_id") @db.Uuid
  companyId         String   @map("company_id") @db.Uuid
  eventId           String?  @map("event_id") @db.Uuid
  action            String
  conditionAtAction String?  @map("condition_at_action")
  createdAt         DateTime @default(now()) @map("created_at")

  asset   Asset   @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  event   Event?  @relation(fields: [eventId], references: [id], onDelete: SetNull)

  @@index([assetId])
  @@index([companyId])
  @@map("asset_logs")
}

// ─────────────────────────────────────────────
// CERTIFICATIONS
// ─────────────────────────────────────────────

model Certification {
  id          String    @id @default(uuid()) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  certType    String    @map("cert_type")
  issueDate   DateTime? @map("issue_date")
  expiryDate  DateTime? @map("expiry_date")
  documentUrl String?   @map("document_url")
  status      String    @default("active")
  createdAt   DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiryDate])
  @@map("certifications")
}

// ─────────────────────────────────────────────
// FORMS
// ─────────────────────────────────────────────

model Form {
  id          String   @id @default(uuid()) @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  name        String
  description String?
  fields      Json     @default("[]")
  icon        String?
  color       String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  company     Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  submissions FormSubmission[]

  @@index([companyId])
  @@map("forms")
}

model FormSubmission {
  id           String    @id @default(uuid()) @db.Uuid
  formId       String    @map("form_id") @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  data         Json      @default("{}")
  status       String    @default("submitted")
  reviewedById String?   @map("reviewed_by_id") @db.Uuid
  reviewedAt   DateTime? @map("reviewed_at")
  reviewNote   String?   @map("review_note")
  createdAt    DateTime  @default(now()) @map("created_at")

  form       Form  @relation(fields: [formId], references: [id], onDelete: Cascade)
  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy User? @relation("FormReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)

  @@index([formId])
  @@index([userId])
  @@map("form_submissions")
}

// ─────────────────────────────────────────────
// QUIZZES
// ─────────────────────────────────────────────

model Quiz {
  id           String   @id @default(uuid()) @db.Uuid
  companyId    String   @map("company_id") @db.Uuid
  title        String
  description  String?
  questions    Json     @default("[]")
  passingScore Int      @default(70) @map("passing_score")
  maxAttempts  Int      @default(3) @map("max_attempts")
  timeLimitMin Int?     @map("time_limit_min")
  icon         String?
  color        String?
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company  Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  attempts QuizAttempt[]

  @@index([companyId])
  @@map("quizzes")
}

model QuizAttempt {
  id          String    @id @default(uuid()) @db.Uuid
  quizId      String    @map("quiz_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  answers     Json      @default("{}")
  score       Int?
  passed      Boolean?
  startedAt   DateTime  @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")

  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([quizId])
  @@index([userId])
  @@map("quiz_attempts")
}

// ─────────────────────────────────────────────
// TRAINING / LMS
// ─────────────────────────────────────────────

model Course {
  id           String   @id @default(uuid()) @db.Uuid
  companyId    String   @map("company_id") @db.Uuid
  title        String
  description  String?
  content      Json     @default("[]")
  isRequired   Boolean  @default(false) @map("is_required")
  passingScore Int      @default(70) @map("passing_score")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  company     Company            @relation(fields: [companyId], references: [id], onDelete: Cascade)
  enrollments CourseEnrollment[]

  @@index([companyId])
  @@map("courses")
}

model CourseEnrollment {
  id          String    @id @default(uuid()) @db.Uuid
  courseId     String    @map("course_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  status      String    @default("assigned")
  progress    Int       @default(0)
  score       Int?
  startedAt   DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  assignedAt  DateTime  @default(now()) @map("assigned_at")

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@map("course_enrollments")
}

// ─────────────────────────────────────────────
// KNOWLEDGE BASE
// ─────────────────────────────────────────────

model KBFolder {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  parentId  String?  @map("parent_id") @db.Uuid
  name      String
  icon      String?
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at")

  company   Company      @relation(fields: [companyId], references: [id], onDelete: Cascade)
  parent    KBFolder?    @relation("FolderTree", fields: [parentId], references: [id], onDelete: Cascade)
  children  KBFolder[]   @relation("FolderTree")
  documents KBDocument[]

  @@index([companyId])
  @@map("kb_folders")
}

model KBDocument {
  id          String   @id @default(uuid()) @db.Uuid
  folderId    String   @map("folder_id") @db.Uuid
  title       String
  type        String   @default("page")
  content     String?
  fileUrl     String?  @map("file_url")
  sortOrder   Int      @default(0) @map("sort_order")
  createdById String   @map("created_by_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  folder    KBFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)
  createdBy User     @relation(fields: [createdById], references: [id], onDelete: Cascade)

  @@index([folderId])
  @@map("kb_documents")
}

// ─────────────────────────────────────────────
// CHAT & MESSAGING
// ─────────────────────────────────────────────

model ChatChannel {
  id          String   @id @default(uuid()) @db.Uuid
  companyId   String   @map("company_id") @db.Uuid
  name        String
  description String?
  type        String   @default("group")
  isArchived  Boolean  @default(false) @map("is_archived")
  createdAt   DateTime @default(now()) @map("created_at")

  company  Company       @relation(fields: [companyId], references: [id], onDelete: Cascade)
  members  ChatMember[]
  messages ChatMessage[]

  @@index([companyId])
  @@map("chat_channels")
}

model ChatMember {
  id        String   @id @default(uuid()) @db.Uuid
  channelId String   @map("channel_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      String   @default("member")
  joinedAt  DateTime @default(now()) @map("joined_at")
  lastReadAt DateTime? @map("last_read_at")

  channel ChatChannel @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([channelId, userId])
  @@map("chat_members")
}

model ChatMessage {
  id        String   @id @default(uuid()) @db.Uuid
  channelId String   @map("channel_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  content   String
  fileUrl   String?  @map("file_url")
  replyToId String?  @map("reply_to_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")
  editedAt  DateTime? @map("edited_at")

  channel ChatChannel  @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user    User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  replyTo ChatMessage? @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies ChatMessage[] @relation("MessageReplies")

  @@index([channelId, createdAt])
  @@map("chat_messages")
}

// ─────────────────────────────────────────────
// FEED / POSTS / UPDATES
// ─────────────────────────────────────────────

model Post {
  id        String   @id @default(uuid()) @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  type      String   @default("update")
  title     String?
  content   String
  isPinned  Boolean  @default(false) @map("is_pinned")
  publishAt DateTime? @map("publish_at")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  company   Company        @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments  PostComment[]
  reactions PostReaction[]

  @@index([companyId, createdAt])
  @@map("posts")
}

model PostComment {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@map("post_comments")
}

model PostReaction {
  id        String   @id @default(uuid()) @db.Uuid
  postId    String   @map("post_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  emoji     String
  createdAt DateTime @default(now()) @map("created_at")

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId, emoji])
  @@map("post_reactions")
}

// ─────────────────────────────────────────────
// NOTIFICATIONS & AUDIT
// ─────────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  companyId String   @map("company_id") @db.Uuid
  title     String
  body      String?
  type      String
  read      Boolean  @default(false)
  actionUrl String?  @map("action_url")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([companyId])
  @@map("notifications")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  companyId  String   @map("company_id") @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String
  entityType String   @map("entity_type")
  entityId   String?  @map("entity_id")
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@map("audit_logs")
}
